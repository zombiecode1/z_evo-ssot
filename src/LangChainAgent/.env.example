# ZombieCoder Agent - Environment Variables

# OpenCode API Configuration (Optional - Free Tier)
OPENCODE_API_KEY=free-tier

# Universal LLM Configuration (Fallback)
# For Ollama (Local)
UNIVERSAL_LLM_BASE=http://localhost:11434/v1
UNIVERSAL_LLM_KEY=local-bypass
UNIVERSAL_LLM_MODEL=qwen2.5-coder:7b

# For Google Gemini (Cloud Fallback)
# UNIVERSAL_LLM_BASE=https://generativelanguage.googleapis.com/v1beta/openai/
# UNIVERSAL_LLM_KEY=YOUR_GEMINI_API_KEY
# UNIVERSAL_LLM_MODEL=gemini-2.0-flash-exp

# Agent Root Path (Optional)
AGENT_ROOT_PATH=./
