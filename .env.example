# ─── Server ───────────────────────────────────────────────
PORT=9999

# ─── Provider API Keys ───────────────────────────────────
# Set one or more API keys. Providers without keys are disabled.
OPENCODE_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ─── LLM Multi-Source Fallback ──────────────────────────
LLM_BASE_URL=http://localhost:9999/v1
LLM_API_KEY=
LLM_MODEL=auto

LLM_FALLBACK_BASE_URL=https://api.smartearningplatformbd.net/v1
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_MODEL=qwen3-coder-next:cloud

LLM_LOCAL_BASE_URL=http://127.0.0.1:5010/v1
LLM_LOCAL_MODEL=llama3.2:1b

# ─── ZombieCoder Agent Models ────────────────────────────
# Each agent type can have its own primary and fallback model.
# The system reads these automatically — no code changes needed.
# Format: ZOMBIE_AGENT_<TYPE>_MODEL and ZOMBIE_AGENT_<TYPE>_FALLBACK

# General agent (default for uncategorized tasks)
ZOMBIE_AGENT_GENERAL_MODEL=mimo-v2.5-free
ZOMBIE_AGENT_GENERAL_FALLBACK=deepseek-v4-flash-free

# Solution Architect — system design, architecture decisions
ZOMBIE_AGENT_ARCHITECT_MODEL=nemotron-3-ultra-free
ZOMBIE_AGENT_ARCHITECT_FALLBACK=big-pickle

# Development Engineer — code generation, bug fixes, refactoring
ZOMBIE_AGENT_ENGINEER_MODEL=deepseek-v4-flash-free
ZOMBIE_AGENT_ENGINEER_FALLBACK=mimo-v2.5-free

# Quality Assurance — testing, validation, defect analysis
ZOMBIE_AGENT_QA_MODEL=big-pickle
ZOMBIE_AGENT_QA_FALLBACK=nemotron-3-ultra-free

# Documentation — technical docs, API guides, runbooks
ZOMBIE_AGENT_DOCS_MODEL=mimo-v2.5-free
ZOMBIE_AGENT_DOCS_FALLBACK=deepseek-v4-flash-free

# Operations — deployment, monitoring, incident response
ZOMBIE_AGENT_OPS_MODEL=nemotron-3-ultra-free
ZOMBIE_AGENT_OPS_FALLBACK=big-pickle

# ─── RAG Settings ──────────────────────────────────────────
# Self-healing SSOT configuration
ZOMBIE_RAG_ENABLED=true
ZOMBIE_RAG_MAX_CHUNKS=5
ZOMBIE_RAG_AUTO_DETECT=true

# ─── Proxi Bridge ──────────────────────────────────────────
PROXI_BRIDGE_URL=http://localhost:9999/v1
PROXI_BRIDGE_KEY=local-proxi

# ─── Workspace ───────────────────────────────────────────
# WORKSPACE_DIR=/home/user/projects
