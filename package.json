{
  "name": "groq-unified-bridge",
  "version": "1.0.0",
  "description": "Unified API bridge for Groq with smart model routing and rate limit management",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc && cp -f src/LangChainAgent/identity.json dist/LangChainAgent/ 2>/dev/null; true",
    "dev": "nodemon --watch 'src/**/*.ts' --exec ts-node src/index.ts",
    "test": "ts-node test/api-test.ts",
    "report": "ts-node test/generate-model-report.ts",
    "mcp-report": "ts-node test/mcp-status-report.ts"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.50",
    "@langchain/core": "^1.1.0",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.4.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/cors": "^2.8.19",
    "@types/multer": "^2.1.0",
    "ai": "^6.0.206",
    "better-sqlite3": "^11.10.0",
    "chokidar": "^4.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "fastembed": "^1.0.0",
    "groq-sdk": "^0.5.0",
    "http-proxy-middleware": "^3.0.7",
    "langchain": "^1.2.10",
    "mcp-use": "^1.28.0",
    "multer": "^2.1.1",
    "openai": "^6.42.0",
    "react": "^18.0.0",
    "react-dom": "^18.3.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/http-proxy-middleware": "^1.0.0",
    "@types/node": "^20.10.0",
    "@types/node-fetch": "^2.6.4",
    "node-fetch": "^2.7.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
